{
  "name": "school-management-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "prisma generate && next dev",
    "dev:clean": "rm -rf .next && prisma generate && next dev",
    "postinstall": "prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-students": "tsx prisma/seed-grade-students.ts",
    "db:check": "tsx prisma/check-db.ts",
    "db:ping": "tsx prisma/db-ping.ts",
    "db:sync-from-render": "bash scripts/sync-from-render.sh",
    "db:push-render": "bash scripts/push-schema-to-render.sh",
    "db:sync-to-render": "bash scripts/sync-to-render.sh",
    "db:deploy-render": "bash scripts/deploy-local-to-render.sh",
    "db:compare-render": "bash -c 'set -a && [ -f .env.render ] && . ./.env.render && set +a && npx tsx prisma/compare-local-render.ts'",
    "db:seed-hr-render": "bash scripts/seed-hr-render.sh",
    "db:sync-hr-to-render": "bash scripts/sync-hr-to-render.sh",
    "db:ensure-hr-manager": "tsx prisma/ensure-hr-manager.ts",
    "db:ensure-settings": "tsx prisma/ensure-system-settings.ts",
    "db:clear-homeroom": "tsx prisma/assign-homeroom.ts",
    "db:sync-subjects": "tsx prisma/sync-subjects.ts",
    "db:ensure-demo": "tsx prisma/ensure-demo-login.ts",
    "db:ensure-demo-render": "bash scripts/ensure-demo-render.sh",
    "db:migrate-payments": "tsx prisma/migrate-semester-payments.ts",
    "db:migrate-photo": "tsx prisma/migrate-photo-url.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts && tsx prisma/ensure-demo-login.ts",
    "db:payment-proofs": "prisma db push && prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "^15.3.3",
    "next-auth": "^5.0.0-beta.28",
    "nodemailer": "^7.0.13",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.25.42"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.8",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.15.29",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "prisma": "^6.9.0",
    "tailwindcss": "^4.1.8",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
