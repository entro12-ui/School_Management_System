generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  PLATFORM_ADMIN
  SUPER_ADMIN
  BRANCH_ADMIN
  REGISTRAR
  TEACHER
  FINANCE_OFFICER
  LIBRARIAN
  HR_OFFICER
  PARENT
  STUDENT
}

enum GradeBand {
  KG
  PRIMARY
  JUNIOR_HIGH
  SENIOR_HIGH
}

enum SeniorStream {
  NATURAL_SCIENCE
  SOCIAL_SCIENCE
  SCIENCE
}

enum AcademicTerm {
  TERM_1
  TERM_2
  SEMESTER_1
  SEMESTER_2
}

enum ClassScheduleDay {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum PaymentStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

enum FeePaymentChannel {
  ONLINE
  CASH
}

enum PaymentProofStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum ChapaTransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

enum BookStatus {
  AVAILABLE
  ISSUED
  LOST
  DAMAGED
}

enum LibraryBorrowerType {
  STUDENT
  TEACHER
}

enum BookReservationStatus {
  PENDING
  READY
  FULFILLED
  CANCELLED
}

enum LibraryFineStatus {
  PENDING
  PAID
  WAIVED
}

enum AssessmentType {
  DAILY_REPORT
  PLAY_BASED
  QUIZ
  MIDTERM
  FINAL
  NATIONAL_PREP
  CONTINUOUS
}

enum AnnouncementAudience {
  ALL
  BRANCH
  GRADE
  PARENTS
  STAFF
}

enum RegistrationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RegistrationRole {
  REGISTRAR
  HR_MANAGER
}

enum SchoolSignupStatus {
  PENDING
  APPROVED
  REJECTED
  PROVISIONED
}

enum PlatformPaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

// ─── SaaS platform (school tenants) ───────────────────────────────────────────

model Organization {
  id           String    @id @default(cuid())
  name         String
  code         String    @unique
  city         String
  address      String?
  phone        String?
  contactEmail String
  studentLimit Int
  isActive     Boolean   @default(true)
  activatedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  branches         Branch[]
  users            User[]
  signupRequest    SchoolSignupRequest?
  platformPayments PlatformPayment[]
}

model SchoolSignupRequest {
  id                String             @id @default(cuid())
  schoolName        String
  city              String
  address           String?
  phone             String?
  contactEmail      String
  contactFirstName  String
  contactLastName   String
  estimatedStudents Int
  status            SchoolSignupStatus @default(PENDING)
  rejectionReason   String?
  reviewedAt        DateTime?
  reviewedById      String?
  organizationId    String?            @unique
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  organization     Organization?     @relation(fields: [organizationId], references: [id])
  reviewedBy       User?             @relation("SchoolSignupReviewer", fields: [reviewedById], references: [id])
  platformPayments PlatformPayment[]

  @@index([status])
  @@index([contactEmail])
}

model PlatformPayment {
  id              String                @id @default(cuid())
  signupRequestId String
  organizationId  String?
  txRef           String                @unique
  amount          Decimal               @db.Decimal(12, 2)
  studentCount    Int
  pricePerStudent Decimal               @default(30) @db.Decimal(10, 2)
  status          PlatformPaymentStatus @default(PENDING)
  chapaReference  String?
  paidAt          DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  signupRequest SchoolSignupRequest @relation(fields: [signupRequestId], references: [id], onDelete: Cascade)
  organization  Organization?       @relation(fields: [organizationId], references: [id])

  @@index([signupRequestId, status])
}

// ─── Organization branches ───────────────────────────────────────────────────

model Branch {
  id             String   @id @default(cuid())
  organizationId String?
  code           String   @unique
  name           String
  city           String
  address        String?
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization         Organization?         @relation(fields: [organizationId], references: [id])
  users                User[]
  academicYears        AcademicYear[]
  classes              Class[]
  students             Student[]
  staffProfiles        StaffProfile[]
  feeStructures        FeeStructure[]
  payments             Payment[]
  attendance           AttendanceRecord[]
  books                Book[]
  bookIssues           BookIssue[]
  bookReservations     BookReservation[]
  libraryFines         LibraryFine[]
  libraryReadingLogs   LibraryReadingLog[]
  studentIdCards       StudentIdCard[]
  classSchedules       ClassScheduleEntry[]
  announcements        Announcement[]
  auditLogs            AuditLog[]
  registrationRequests RegistrationRequest[]
  hrDepartments        HrDepartment[]
  hrDesignations       HrDesignation[]
  hrEmployees          HrEmployee[]
  hrLeaveTypes         HrLeaveType[]
  hrTrainings          HrTraining[]
  hrAssets             HrAsset[]
  hrJobPosts           HrJobPost[]
  hrEmployeeIdCards    HrEmployeeIdCard[]
}

model AcademicYear {
  id        String   @id @default(cuid())
  branchId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  createdAt DateTime @default(now())

  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  classes  Class[]
  payments Payment[]

  @@unique([branchId, name])
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  email              String    @unique
  passwordHash       String
  firstName          String
  lastName           String
  phone              String?
  photoUrl           String?
  role               UserRole
  organizationId     String?
  branchId           String?
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  pendingOtp         String?
  otpIssuedAt        DateTime?
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  organization                Organization?         @relation(fields: [organizationId], references: [id])
  branch                      Branch?               @relation(fields: [branchId], references: [id])
  staffProfile                StaffProfile?
  parentProfile               ParentProfile?
  student                     Student?
  auditLogs                   AuditLog[]            @relation("AuditActor")
  messagesSent                Message[]             @relation("MessageSender")
  reviewedRegistrations       RegistrationRequest[] @relation("RegistrationReviewer")
  reviewedSchoolSignups       SchoolSignupRequest[] @relation("SchoolSignupReviewer")
  hrUserRoles                 HrUserRole[]
  hrEmployee                  HrEmployee?
  hrLeaveApprovals            HrLeaveRequest[]      @relation("LeaveApprover")
  hrPerformanceReviews        HrPerformanceReview[] @relation("PerformanceReviewer")
  paymentProofsSubmitted      PaymentProof[]        @relation("PaymentProofSubmitter")
  paymentProofsReviewed       PaymentProof[]        @relation("PaymentProofReviewer")
  chapaTransactionsInitiated  ChapaTransaction[]    @relation("ChapaTransactionInitiator")
  libraryBorrowals            BookIssue[]           @relation("LibraryBorrower")
  libraryReservations         BookReservation[]     @relation("LibraryReservationBorrower")
  libraryFines                LibraryFine[]         @relation("LibraryFineBorrower")
  createdStudentIdCards       StudentIdCard[]       @relation("StudentIdCardCreator")
  createdHrEmployeeIdCards    HrEmployeeIdCard[]    @relation("HrEmployeeIdCardCreator")
  assignedScheduleUnitLeaders StaffProfile[]        @relation("ScheduleUnitLeaderAssigner")
  createdClassSchedules       ClassScheduleEntry[]  @relation("ClassScheduleCreator")

  @@index([role])
  @@index([branchId])
}

model RegistrationRequest {
  id                  String             @id @default(cuid())
  branchId            String
  role                RegistrationRole
  status              RegistrationStatus @default(PENDING)
  email               String
  passwordHash        String?
  firstName           String
  lastName            String
  phone               String?
  dateOfBirth         DateTime?
  gender              String?
  gradeLevel          Int?
  gradeBand           GradeBand?
  stream              SeniorStream?
  guardianName        String?
  guardianPhone       String?
  department          String?
  requestedSubjectIds Json?
  reviewedAt          DateTime?
  reviewedById        String?
  rejectionReason     String?
  createdUserId       String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  branch     Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("RegistrationReviewer", fields: [reviewedById], references: [id])

  @@index([branchId, status])
  @@index([email])
  @@index([status])
}

model StaffProfile {
  id                             String    @id @default(cuid())
  userId                         String    @unique
  branchId                       String
  employeeId                     String
  department                     String?
  hireDate                       DateTime?
  isScheduleUnitLeader           Boolean   @default(false)
  scheduleUnitLeaderAssignedAt   DateTime?
  scheduleUnitLeaderAssignedById String?
  createdAt                      DateTime  @default(now())

  user                         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch                       Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  scheduleUnitLeaderAssignedBy User?  @relation("ScheduleUnitLeaderAssigner", fields: [scheduleUnitLeaderAssignedById], references: [id], onDelete: SetNull)

  classAssignments       ClassTeacher[]
  subjectsTaught         Subject[]            @relation("SubjectTeacher")
  staffSubjects          StaffSubject[]
  classSchedules         ClassScheduleEntry[] @relation("ClassScheduleTeacher")
  preparedClassSchedules ClassScheduleEntry[] @relation("ClassSchedulePreparer")

  @@unique([branchId, employeeId])
  @@index([branchId, isScheduleUnitLeader])
}

model StaffSubject {
  id        String   @id @default(cuid())
  staffId   String
  subjectId String
  createdAt DateTime @default(now())

  staff   StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  subject Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([staffId, subjectId])
}

model ParentProfile {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  children Student[] @relation("StudentGuardian")
}

// ─── Academic Structure ──────────────────────────────────────────────────────

model Class {
  id             String        @id @default(cuid())
  branchId       String
  academicYearId String
  name           String
  gradeLevel     Int
  gradeBand      GradeBand
  stream         SeniorStream?
  roomNumber     String?
  capacity       Int           @default(40)
  createdAt      DateTime      @default(now())

  branch       Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  academicYear AcademicYear         @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  students     Student[]
  teachers     ClassTeacher[]
  subjects     ClassSubject[]
  schedules    ClassScheduleEntry[]
  assessments  Assessment[]
  attendance   AttendanceRecord[]

  @@unique([branchId, academicYearId, name])
  @@index([gradeBand])
}

model Subject {
  id        String    @id @default(cuid())
  code      String
  name      String
  gradeBand GradeBand
  isCore    Boolean   @default(true)
  teacherId String?
  createdAt DateTime  @default(now())

  teacher          StaffProfile?        @relation("SubjectTeacher", fields: [teacherId], references: [id])
  classLinks       ClassSubject[]
  classSchedules   ClassScheduleEntry[]
  assessments      Assessment[]
  staffAssignments StaffSubject[]

  @@unique([code, gradeBand])
}

model ClassSubject {
  id        String @id @default(cuid())
  classId   String
  subjectId String

  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([classId, subjectId])
}

model ClassTeacher {
  id        String   @id @default(cuid())
  classId   String
  teacherId String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  class   Class        @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacher StaffProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([classId, teacherId])
}

model ClassScheduleEntry {
  id           String           @id @default(cuid())
  branchId     String
  classId      String
  subjectId    String
  teacherId    String
  day          ClassScheduleDay
  period       Int
  startTime    String?
  endTime      String?
  room         String?
  notes        String?
  preparedById String?
  createdById  String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  branch     Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  class      Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject    Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher    StaffProfile  @relation("ClassScheduleTeacher", fields: [teacherId], references: [id], onDelete: Cascade)
  preparedBy StaffProfile? @relation("ClassSchedulePreparer", fields: [preparedById], references: [id], onDelete: SetNull)
  createdBy  User?         @relation("ClassScheduleCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([classId, day, period])
  @@unique([teacherId, day, period])
  @@index([branchId, day, period])
  @@index([subjectId])
}

// ─── Students ─────────────────────────────────────────────────────────────────

model Student {
  id             String        @id @default(cuid())
  userId         String?       @unique
  branchId       String
  classId        String?
  studentId      String
  firstName      String
  lastName       String
  dateOfBirth    DateTime?
  gender         String?
  gradeBand      GradeBand
  gradeLevel     Int
  stream         SeniorStream?
  enrollmentDate DateTime      @default(now())
  isActive       Boolean       @default(true)
  guardianId     String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user             User?               @relation(fields: [userId], references: [id])
  branch           Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  class            Class?              @relation(fields: [classId], references: [id])
  guardian         ParentProfile?      @relation("StudentGuardian", fields: [guardianId], references: [id])
  grades           GradeRecord[]
  attendance       AttendanceRecord[]
  payments         Payment[]
  bookIssues       BookIssue[]
  bookReservations BookReservation[]
  readingLogs      LibraryReadingLog[]
  gpaRecords       GpaRecord[]
  idCards          StudentIdCard[]

  @@unique([branchId, studentId])
  @@index([gradeBand, gradeLevel])
}

model StudentIdCard {
  id          String    @id @default(cuid())
  branchId    String
  studentId   String
  cardNumber  String
  issueDate   DateTime  @default(now())
  expiresAt   DateTime?
  status      String    @default("ACTIVE")
  notes       String?
  printedAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("StudentIdCardCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([branchId, cardNumber])
  @@index([studentId, status])
  @@index([branchId, createdAt])
}

model GpaRecord {
  id         String       @id @default(cuid())
  studentId  String
  term       AcademicTerm
  yearLabel  String
  gpa        Float
  cumulative Float?
  createdAt  DateTime     @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, term, yearLabel])
}

// ─── Academic Records ─────────────────────────────────────────────────────────

model Assessment {
  id            String         @id @default(cuid())
  classId       String
  subjectId     String
  title         String
  type          AssessmentType
  term          AcademicTerm?
  maxScore      Float          @default(100)
  weight        Float          @default(1)
  weightPercent Float?
  sheetKey      String?
  sortOrder     Int            @default(0)
  date          DateTime       @default(now())
  createdAt     DateTime       @default(now())

  class   Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  subject Subject       @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  grades  GradeRecord[]

  @@index([type])
  @@index([sheetKey])
}

model GradeRecord {
  id           String   @id @default(cuid())
  assessmentId String
  studentId    String
  score        Float
  remarks      String?
  enteredBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assessmentId, studentId])
}

// ─── Attendance ───────────────────────────────────────────────────────────────

model AttendanceRecord {
  id        String           @id @default(cuid())
  branchId  String
  classId   String?
  studentId String?
  staffId   String?
  date      DateTime         @db.Date
  status    AttendanceStatus
  checkIn   DateTime?
  method    String?
  notes     String?
  createdAt DateTime         @default(now())

  branch  Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  class   Class?   @relation(fields: [classId], references: [id])
  student Student? @relation(fields: [studentId], references: [id])

  @@index([date, branchId])
  @@index([studentId, date])
}

// ─── Finance ──────────────────────────────────────────────────────────────────

model FeeStructure {
  id         String        @id @default(cuid())
  branchId   String
  name       String
  gradeBand  GradeBand?
  gradeLevel Int?
  stream     SeniorStream?
  amount     Decimal       @db.Decimal(12, 2)
  term       AcademicTerm?
  isActive   Boolean       @default(true)
  createdAt  DateTime      @default(now())

  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  payments Payment[]
}

model Payment {
  id             String             @id @default(cuid())
  branchId       String
  studentId      String
  academicYearId String
  term           AcademicTerm
  feeStructureId String?
  amount         Decimal            @db.Decimal(12, 2)
  paidAmount     Decimal            @default(0) @db.Decimal(12, 2)
  status         PaymentStatus      @default(PENDING)
  paidChannel    FeePaymentChannel?
  dueDate        DateTime?
  paidAt         DateTime?
  reference      String?
  scholarship    Boolean            @default(false)
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  branch       Branch         @relation(fields: [branchId], references: [id], onDelete: Cascade)
  student      Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear   @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  feeStructure FeeStructure?  @relation(fields: [feeStructureId], references: [id])
  proofs       PaymentProof[]
  chapaTransactions ChapaTransaction[]

  @@unique([studentId, academicYearId, term])
  @@index([status, branchId])
  @@index([academicYearId, term])
}

/// Parent/student uploads payment receipt; finance approves (online) or records cash at desk.
model PaymentProof {
  id              String             @id @default(cuid())
  paymentId       String
  submittedById   String
  amount          Decimal            @db.Decimal(12, 2)
  channel         FeePaymentChannel  @default(ONLINE)
  status          PaymentProofStatus @default(PENDING_REVIEW)
  reference       String?
  invoiceUrl      String
  notes           String?
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  payment     Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  submittedBy User    @relation("PaymentProofSubmitter", fields: [submittedById], references: [id])
  reviewedBy  User?   @relation("PaymentProofReviewer", fields: [reviewedById], references: [id])

  @@index([paymentId, status])
  @@index([status, createdAt])
}

/// Chapa checkout session for semester fee payments.
model ChapaTransaction {
  id            String                 @id @default(cuid())
  paymentId     String
  txRef         String                 @unique
  amount        Decimal                @db.Decimal(12, 2)
  status        ChapaTransactionStatus @default(PENDING)
  chapaRefId    String?
  initiatedById String
  createdAt     DateTime               @default(now())
  completedAt   DateTime?

  payment     Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  initiatedBy User    @relation("ChapaTransactionInitiator", fields: [initiatedById], references: [id])

  @@index([paymentId, status])
  @@index([status, createdAt])
}

// ─── Library ──────────────────────────────────────────────────────────────────

model Book {
  id            String     @id @default(cuid())
  branchId      String
  isbn          String?
  barcode       String?
  title         String
  author        String?
  subject       String?
  category      String?
  gradeBand     GradeBand?
  shelfLocation String?
  description   String?
  digitalUrl    String?
  isDigital     Boolean    @default(false)
  totalCopies   Int        @default(1)
  available     Int        @default(1)
  status        BookStatus @default(AVAILABLE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt

  branch       Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  issues       BookIssue[]
  reservations BookReservation[]
  readingLogs  LibraryReadingLog[]

  @@unique([branchId, barcode])
  @@index([gradeBand])
  @@index([subject])
}

model BookIssue {
  id             String              @id @default(cuid())
  branchId       String
  bookId         String
  borrowerUserId String
  borrowerType   LibraryBorrowerType
  studentId      String?
  issuedAt       DateTime            @default(now())
  dueDate        DateTime
  returnedAt     DateTime?
  fineAmount     Decimal?            @db.Decimal(10, 2)
  finePaid       Boolean             @default(false)
  notes          String?

  branch   Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  book     Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  borrower User          @relation("LibraryBorrower", fields: [borrowerUserId], references: [id], onDelete: Cascade)
  student  Student?      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  fines    LibraryFine[]

  @@index([borrowerUserId, returnedAt])
  @@index([studentId])
}

model BookReservation {
  id             String                @id @default(cuid())
  branchId       String
  bookId         String
  borrowerUserId String
  studentId      String?
  status         BookReservationStatus @default(PENDING)
  reservedAt     DateTime              @default(now())
  readyAt        DateTime?
  expiresAt      DateTime?
  notes          String?

  branch   Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)
  book     Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  borrower User     @relation("LibraryReservationBorrower", fields: [borrowerUserId], references: [id], onDelete: Cascade)
  student  Student? @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([bookId, status])
  @@index([borrowerUserId, status])
}

model LibraryFine {
  id             String            @id @default(cuid())
  branchId       String
  issueId        String
  borrowerUserId String
  amount         Decimal           @db.Decimal(10, 2)
  paidAmount     Decimal           @default(0) @db.Decimal(10, 2)
  status         LibraryFineStatus @default(PENDING)
  paidAt         DateTime?
  createdAt      DateTime          @default(now())

  branch   Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  issue    BookIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  borrower User      @relation("LibraryFineBorrower", fields: [borrowerUserId], references: [id], onDelete: Cascade)

  @@index([borrowerUserId, status])
}

model LibraryReadingLog {
  id          String   @id @default(cuid())
  branchId    String
  studentId   String
  bookId      String?
  bookTitle   String
  completedAt DateTime @default(now())
  term        String?
  badgeLevel  String?

  branch  Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  book    Book?   @relation(fields: [bookId], references: [id], onDelete: SetNull)

  @@index([studentId])
}

// ─── Communication ────────────────────────────────────────────────────────────

model Announcement {
  id        String               @id @default(cuid())
  branchId  String?
  title     String
  body      String
  audience  AnnouncementAudience @default(ALL)
  gradeBand GradeBand?
  published Boolean              @default(true)
  createdAt DateTime             @default(now())

  branch Branch? @relation(fields: [branchId], references: [id])
}

model Message {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  subject    String?
  body       String
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())

  sender User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
}

// ─── Audit & Settings ─────────────────────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  branchId  String?
  actorId   String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  branch Branch? @relation(fields: [branchId], references: [id])
  actor  User?   @relation("AuditActor", fields: [actorId], references: [id])

  @@index([createdAt])
  @@index([branchId])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

// ─── HR Module (tenant = Branch) ─────────────────────────────────────────────

enum HrEmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
}

enum HrEmployeeStatus {
  ACTIVE
  ON_LEAVE
  PROBATION
  TERMINATED
}

enum HrLeaveRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum HrAttendanceMethod {
  MANUAL
  BIOMETRIC
  RFID
  MOBILE
}

enum HrJobPostStatus {
  DRAFT
  OPEN
  CLOSED
}

enum HrCandidateStatus {
  APPLIED
  SHORTLISTED
  INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum HrTrainingEnrollmentStatus {
  ENROLLED
  IN_PROGRESS
  COMPLETED
  DROPPED
}

enum HrAssetStatus {
  AVAILABLE
  ASSIGNED
  MAINTENANCE
  RETIRED
}

enum HrDisciplinaryStatus {
  OPEN
  RESOLVED
  APPEALED
}

model HrDepartment {
  id          String   @id @default(cuid())
  branchId    String
  name        String
  description String?
  createdAt   DateTime @default(now())

  branch    Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employees HrEmployee[]
  jobPosts  HrJobPost[]

  @@unique([branchId, name])
  @@index([branchId])
}

model HrDesignation {
  id          String   @id @default(cuid())
  branchId    String
  title       String
  salaryGrade String?
  createdAt   DateTime @default(now())

  branch    Branch       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employees HrEmployee[]

  @@unique([branchId, title])
  @@index([branchId])
}

model HrEmployee {
  id              String           @id @default(cuid())
  branchId        String
  departmentId    String?
  designationId   String?
  userId          String?          @unique
  employeeCode    String
  firstName       String
  lastName        String
  email           String
  phone           String?
  dob             DateTime?        @db.Date
  gender          String?
  joiningDate     DateTime?        @db.Date
  contractEndDate DateTime?        @db.Date
  employmentType  HrEmploymentType @default(FULL_TIME)
  status          HrEmployeeStatus @default(ACTIVE)
  profilePhotoUrl String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  branch           Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  department       HrDepartment?          @relation(fields: [departmentId], references: [id])
  designation      HrDesignation?         @relation(fields: [designationId], references: [id])
  user             User?                  @relation(fields: [userId], references: [id])
  documents        HrEmployeeDocument[]
  attendance       HrEmployeeAttendance[]
  leaveRequests    HrLeaveRequest[]
  salary           HrSalaryStructure?
  payrolls         HrPayrollRecord[]
  reviews          HrPerformanceReview[]  @relation("ReviewedEmployee")
  reviewsGiven     HrPerformanceReview[]  @relation("PerformanceReviewerEmployee")
  trainings        HrTrainingEnrollment[]
  assetAssignments HrAssetAssignment[]
  disciplinary     HrDisciplinaryAction[]
  idCards          HrEmployeeIdCard[]

  @@unique([branchId, employeeCode])
  @@index([branchId, status])
  @@index([departmentId])
}

model HrEmployeeIdCard {
  id          String    @id @default(cuid())
  branchId    String
  employeeId  String
  cardNumber  String
  issueDate   DateTime  @default(now())
  expiresAt   DateTime?
  status      String    @default("ACTIVE")
  notes       String?
  printedAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  branch    Branch     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  employee  HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdBy User?      @relation("HrEmployeeIdCardCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([branchId, cardNumber])
  @@index([employeeId, status])
  @@index([branchId, createdAt])
}

model HrEmployeeDocument {
  id           String    @id @default(cuid())
  employeeId   String
  documentType String
  fileUrl      String
  expiryDate   DateTime? @db.Date
  createdAt    DateTime  @default(now())

  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model HrEmployeeAttendance {
  id              String             @id @default(cuid())
  employeeId      String
  attendanceDate  DateTime           @db.Date
  checkIn         DateTime?          @db.Time(0)
  checkOut        DateTime?          @db.Time(0)
  method          HrAttendanceMethod @default(MANUAL)
  overtimeMinutes Int                @default(0)
  anomalyFlag     Boolean            @default(false)
  createdAt       DateTime           @default(now())

  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, attendanceDate])
  @@index([attendanceDate])
}

model HrLeaveType {
  id       String @id @default(cuid())
  branchId String
  name     String
  maxDays  Int

  branch   Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  requests HrLeaveRequest[]

  @@unique([branchId, name])
}

model HrLeaveRequest {
  id          String               @id @default(cuid())
  employeeId  String
  leaveTypeId String
  startDate   DateTime             @db.Date
  endDate     DateTime             @db.Date
  status      HrLeaveRequestStatus @default(PENDING)
  approverId  String?
  remarks     String?
  createdAt   DateTime             @default(now())

  employee  HrEmployee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType HrLeaveType @relation(fields: [leaveTypeId], references: [id])
  approver  User?       @relation("LeaveApprover", fields: [approverId], references: [id])

  @@index([employeeId, status])
}

model HrSalaryStructure {
  id                String  @id @default(cuid())
  employeeId        String  @unique
  baseSalary        Decimal @db.Decimal(12, 2)
  allowances        Decimal @default(0) @db.Decimal(12, 2)
  taxPercentage     Decimal @default(0) @db.Decimal(5, 2)
  pensionPercentage Decimal @default(0) @db.Decimal(5, 2)

  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
}

model HrPayrollRecord {
  id           String   @id @default(cuid())
  employeeId   String
  payrollMonth String
  grossSalary  Decimal  @db.Decimal(12, 2)
  deductions   Decimal  @db.Decimal(12, 2)
  netSalary    Decimal  @db.Decimal(12, 2)
  generatedAt  DateTime @default(now())

  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, payrollMonth])
  @@index([payrollMonth])
}

model HrPerformanceReview {
  id                   String   @id @default(cuid())
  employeeId           String
  reviewerId           String?
  reviewerEmployeeId   String?
  reviewPeriod         String
  kpiScore             Decimal? @db.Decimal(5, 2)
  feedback             String?
  promotionRecommended Boolean  @default(false)
  createdAt            DateTime @default(now())

  employee         HrEmployee  @relation("ReviewedEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer         User?       @relation("PerformanceReviewer", fields: [reviewerId], references: [id])
  reviewerEmployee HrEmployee? @relation("PerformanceReviewerEmployee", fields: [reviewerEmployeeId], references: [id])

  @@index([employeeId])
}

model HrTraining {
  id          String    @id @default(cuid())
  branchId    String
  title       String
  description String?
  startDate   DateTime? @db.Date
  endDate     DateTime? @db.Date
  createdAt   DateTime  @default(now())

  branch      Branch                 @relation(fields: [branchId], references: [id], onDelete: Cascade)
  enrollments HrTrainingEnrollment[]

  @@index([branchId])
}

model HrTrainingEnrollment {
  id                   String                     @id @default(cuid())
  trainingId           String
  employeeId           String
  status               HrTrainingEnrollmentStatus @default(ENROLLED)
  completionPercentage Decimal                    @default(0) @db.Decimal(5, 2)

  training HrTraining @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([trainingId, employeeId])
}

model HrAsset {
  id           String        @id @default(cuid())
  branchId     String
  assetName    String
  assetType    String
  serialNumber String?
  status       HrAssetStatus @default(AVAILABLE)
  createdAt    DateTime      @default(now())

  branch      Branch              @relation(fields: [branchId], references: [id], onDelete: Cascade)
  assignments HrAssetAssignment[]

  @@index([branchId, status])
}

model HrAssetAssignment {
  id           String    @id @default(cuid())
  assetId      String
  employeeId   String
  assignedDate DateTime  @db.Date
  returnDate   DateTime? @db.Date

  asset    HrAsset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model HrDisciplinaryAction {
  id          String               @id @default(cuid())
  employeeId  String
  actionType  String
  description String
  actionDate  DateTime             @db.Date
  status      HrDisciplinaryStatus @default(OPEN)

  employee HrEmployee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
}

model HrJobPost {
  id           String          @id @default(cuid())
  branchId     String
  departmentId String?
  title        String
  description  String?
  closingDate  DateTime?       @db.Date
  status       HrJobPostStatus @default(OPEN)
  createdAt    DateTime        @default(now())

  branch     Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  department HrDepartment? @relation(fields: [departmentId], references: [id])
  candidates HrCandidate[]

  @@index([branchId, status])
}

model HrCandidate {
  id               String            @id @default(cuid())
  jobPostId        String
  fullName         String
  email            String
  resumeUrl        String?
  parsedResumeData Json?
  aiScore          Decimal?          @db.Decimal(5, 2)
  status           HrCandidateStatus @default(APPLIED)
  createdAt        DateTime          @default(now())

  jobPost HrJobPost @relation(fields: [jobPostId], references: [id], onDelete: Cascade)

  @@index([jobPostId, status])
}

model HrRole {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  permissions HrRolePermission[]
  userRoles   HrUserRole[]
}

model HrPermission {
  id   String @id @default(cuid())
  name String @unique

  roles HrRolePermission[]
}

model HrRolePermission {
  roleId       String
  permissionId String

  role       HrRole       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission HrPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model HrUserRole {
  userId String
  roleId String

  user User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role HrRole @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}
