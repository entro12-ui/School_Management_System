# Copy to .env.render and fill in from Render Dashboard → Postgres → Connections

# External Database URL (add schema if missing)
RENDER_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require&schema=school_sms"

# Local Docker Postgres (same as docker-compose)
LOCAL_DATABASE_URL="postgresql://postgres:password@localhost:5434/school_management?schema=school_sms"
