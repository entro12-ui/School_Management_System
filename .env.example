# Active connection for the app (use local after syncing from Render)
DATABASE_URL="postgresql://postgres:password@localhost:5434/school_management?schema=school_sms"

# --- Render Postgres (two URLs — do not swap them) ---
# INTERNAL → Render Web Service DATABASE_URL only (app running on Render)
# EXTERNAL → .env.render RENDER_DATABASE_URL only (sync from your laptop)
#
# RENDER_DATABASE_URL="postgresql://USER:PASSWORD@HOST.REGION-postgres.render.com/DATABASE?sslmode=require&schema=school_sms"

# Render URLs: copy .env.render.example → .env.render (gitignored) and paste External URL.
#
# Local ← Render (download production into Docker):
#   npm run db:sync-from-render
#
# Local → Render (recommended — schema + ALL local data):
#   npm run db:deploy-render
#   npm run db:deploy-render -- --yes   # no confirmation prompt
#
# Other:
#   npm run db:push-render        # schema only on Render
#   npm run db:sync-to-render     # data only (overwrites Render)
#   npm run db:compare-render     # row counts local vs Render
#   npm run db:seed-hr-render     # HR demo seed on Render only

# Optional: cap connections when using serverless / many instances
# DATABASE_URL="postgresql://...?sslmode=require&schema=school_sms&connection_limit=5"

AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# Auth.js v5 — same as NEXTAUTH_URL in production; trust host behind Render proxy
# AUTH_URL="https://your-app.onrender.com"
# AUTH_TRUST_HOST="true"

# --- Ollama AI Tutor (local) ---
# Install: https://ollama.com — then: ollama pull llama3.1:8b
OLLAMA_BASE_URL="http://127.0.0.1:11434"
# qwen2.5:7b — faster on CPU; llama3.1:8b — higher quality but slower
OLLAMA_MODEL="qwen2.5:7b"
AI_TUTOR_ENABLED="true"
AI_TUTOR_FALLBACK_MOCK="true"
# First-token wait (model load on CPU can exceed 30s). Idle gap after streaming starts:
OLLAMA_TIMEOUT_MS="120000"
# OLLAMA_FIRST_TOKEN_TIMEOUT_MS="120000"
# OLLAMA_STREAM_IDLE_TIMEOUT_MS="45000"
OLLAMA_NUM_PREDICT="140"
OLLAMA_NUM_CTX="3072"
OLLAMA_MAX_HISTORY="4"
OLLAMA_KEEP_ALIVE="15m"

# Render production (web service only — not for local .env):
# OLLAMA_BASE_URL="http://school-sms-ollama:11434"

# --- Chapa payments (Ethiopia) ---
# Dashboard: https://dashboard.chapa.co — use TEST keys locally, LIVE keys in production.
# Callback URL (set in Chapa dashboard if required): https://your-app/api/chapa/callback
CHAPA_SECRET_KEY="CHASECK_TEST-your-secret-key"
CHAPA_PUBLIC_KEY="CHAPUBK_TEST-your-public-key"
# Optional: platform SaaS billing (ETB per student for new school signups)
# PLATFORM_STUDENT_PRICE_ETB="30"

# --- Email (school payment links on approval) ---
# Option A — Gmail / SMTP (use a Google App Password, not your normal password)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="your@gmail.com"
# SMTP_PASS="your-16-char-app-password"
# MAIL_FROM="EduSync SMS <your@gmail.com>"
# Optional BCC for platform owner on payment-link emails:
# MAIL_TO="admin@yourcompany.com"
# RESEND_API_KEY="re_xxxxxxxx"
# MAIL_FROM="EduSync SMS <onboarding@resend.dev>"
