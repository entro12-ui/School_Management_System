# Copy to .env and adjust

DATABASE_URL="postgresql://postgres:password@localhost:5432/school_management?schema=school_sms"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# --- Ollama AI Tutor (local) ---
# Install: https://ollama.com — then: ollama pull llama3.1:8b
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="llama3.1:8b"
AI_TUTOR_ENABLED="true"
AI_TUTOR_FALLBACK_MOCK="true"
OLLAMA_TIMEOUT_MS="12000"
OLLAMA_NUM_PREDICT="140"
OLLAMA_NUM_CTX="3072"
OLLAMA_MAX_HISTORY="4"
OLLAMA_KEEP_ALIVE="15m"

# Render production (web service only — not for local .env):
# OLLAMA_BASE_URL="http://school-sms-ollama:11434"
