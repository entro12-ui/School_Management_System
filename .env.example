# Active connection for the app (use local after syncing from Render)
DATABASE_URL="postgresql://postgres:password@localhost:5434/school_management?schema=school_sms"

# --- Render (production / source of truth) ---
# External URL from Render Dashboard → Postgres → Connections
# RENDER_DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Copy full Render data into local Docker DB:
#   npm run db:sync-from-render
#
# Push HR schema + seed to Render (resume DB in dashboard first):
#   npm run db:push-render        # schema only — keeps existing Render data
#   npm run db:seed-hr-render     # HR user + sample HR rows
#   npm run db:sync-to-render     # full local → Render (overwrites Render)

# Optional: cap connections when using serverless / many instances
# DATABASE_URL="postgresql://...?sslmode=require&schema=school_sms&connection_limit=5"

AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# Optional — for future AI features
# OPENAI_API_KEY=""
